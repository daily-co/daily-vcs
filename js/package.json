  "scripts": {
    "devrig": "wrap () { VCS_TARGET=devrig VCS_COMPID=\"$*\" vite serve; }; wrap",
    "open-browser-hello": "VCS_TARGET=devrig VCS_COMPID=example:hello vite serve --open",
    "open-browser": "wrap () { VCS_TARGET=devrig VCS_COMPID=\"$*\" vite serve --open; }; wrap",
    "build-browser": "wrap () { VCS_TARGET=devrig VCS_USE_COMP_FILENAME=1 VCS_COMPID=\"$*\" vite build; }; wrap",
    "build-composition-module-for-web": "wrap () { VCS_TARGET=module_web VCS_COMPID=\"$1\" VCS_VCSROOT=\"$2\" vite build; }; wrap",
    "benchmark-graphics-test": "node vcs-benchmark.js --comp example/graphics-test.jsx",
    "test-scenario": "node vcs-test-runner.js --scenario",
    "line-protocol": "node vcs-line-protocol-main.js --compid"
  }
